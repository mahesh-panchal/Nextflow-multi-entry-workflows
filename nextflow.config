// ---------------------------------------------------------------------------
// Manifest
// ---------------------------------------------------------------------------
manifest {
    name            = 'nextflow-best-practices'
    author          = 'Mahesh Binzer-Panchal'
    homePage        = 'https://github.com/mahesh-panchal/Nextflow-best-practices'
    description     = 'A demonstration of advanced Nextflow and nf-core best practices.'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=25.10.0'
    version         = '1.0.0'
}

params {
    // ---------------------------------------------------------------------------
    // Input / output
    // ---------------------------------------------------------------------------
    // stages            = null   // Defined by pipeline
    input             = null   // path: samplesheet CSV (sample,fastq_1,fastq_2,strandedness)
    outdir            = 'results'

    // ---------------------------------------------------------------------------
    // Reference data (required for quant_data.nf and main.nf)
    // ---------------------------------------------------------------------------
    genome_fasta      = null   // path: genome FASTA
    gtf               = null   // path: genome annotation GTF
    transcript_fasta  = null   // path: transcript sequences FASTA

    // ---------------------------------------------------------------------------
    // Test data (used by nf-test; resolves nf-core test-datasets URLs)
    // ---------------------------------------------------------------------------
    modules_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
}

// ---------------------------------------------------------------------------
// Plugins
// ---------------------------------------------------------------------------
plugins {
    id 'nf-schema@2.3.0'
}

// nf-schema: point to the pipeline parameter schema
validation {
    monochromeLogs = false
    help {
        enabled        = true
        shortParameter = 'help'
        fullParameter  = 'help_full'
    }
    summary {
        beforeText = '\n'
        afterText  = '\n'
    }
}

// ---------------------------------------------------------------------------
// Output publishing (global defaults; output{} blocks live in each .nf script)
// ---------------------------------------------------------------------------
outputDir = params.outdir
workflow {
    output {
        mode    = 'copy'
        enabled = true
    }
}

// ---------------------------------------------------------------------------
// Process defaults
// ---------------------------------------------------------------------------
process {
    cpus   = 2
    memory = '4.GB'
    time   = '1.h'

    withLabel: 'process_single' {
        cpus   = 1
        memory = '1.GB'
        time   = '30.m'
    }

    withLabel: 'process_medium' {
        cpus   = 4
        memory = '16.GB'
        time   = '4.h'
    }
}

// ---------------------------------------------------------------------------
// Profiles
// ---------------------------------------------------------------------------
profiles {
    docker {
        // nf-core module containers use 'biocontainers/' shorthand which now
        // resolves to quay.io/biocontainers/ rather than Docker Hub.
        docker {
            enabled    = true
            runOptions = '-u $(id -u):$(id -g)'
            registry   = 'quay.io'
        }
        conda       { enabled = false }
        singularity { enabled = false }
    }

    singularity {
        singularity {
            enabled    = true
            autoMounts = true
        }
        docker { enabled = false }
        conda  { enabled = false }
    }

    conda {
        conda       { enabled = true  }
        docker      { enabled = false }
        singularity { enabled = false }
    }
}

