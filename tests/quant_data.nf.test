nextflow_pipeline {

    name "Test Pipeline quant_data.nf"
    script "../quant_data.nf"
    tag "pipeline"
    tag "quant_data"

    // -------------------------------------------------------------------------
    // Stub run — exercises wiring and container resolution via stub: blocks.
    // -------------------------------------------------------------------------
    test("sarscov2 - paired_end stub") {

        options "-stub"

        when {
            params {
                modules_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
                input            = "$projectDir/tests/data/samplesheet.csv"
                outdir           = "$outputDir"
                genome_fasta     = "https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/genome/genome.fasta"
                gtf              = "https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/sarscov2/genome/genome.gtf"
                transcript_fasta = "https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/sarscov2/genome/transcriptome.fasta"
            }
        }

        then {
            assertAll(
                { assert workflow.success }
            )
        }
    }

    // -------------------------------------------------------------------------
    // Single-end: full execution — index built internally by QUANT_DATA
    // -------------------------------------------------------------------------
    test("sarscov2 - single_end") {

        when {
            params {
                modules_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
                input            = "$projectDir/tests/data/samplesheet_single_end.csv"
                outdir           = "$outputDir"
                genome_fasta     = "https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/genome/genome.fasta"
                gtf              = "https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/sarscov2/genome/genome.gtf"
                transcript_fasta = "https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/sarscov2/genome/transcriptome.fasta"
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.trace.succeeded().size() > 0 },
                { assert path("$outputDir/salmon").exists() },
                { assert snapshot(
                    // Snapshot only deterministic quantification outputs;
                    // aux_info/ (fld.gz, meta_info.json) and logs/ (salmon_quant.log)
                    // are non-deterministic and excluded.
                    path("$outputDir/salmon/test/quant.sf"),
                    path("$outputDir/salmon/test/quant.genes.sf"),
                    path("$outputDir/salmon/test/lib_format_counts.json"),
                    path("$outputDir/salmon/test/cmd_info.json")
                ).match() }
            )
        }
    }

    // -------------------------------------------------------------------------
    // Paired-end: full execution — index built internally by QUANT_DATA
    // -------------------------------------------------------------------------
    test("sarscov2 - paired_end") {

        when {
            params {
                modules_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
                input            = "$projectDir/tests/data/samplesheet.csv"
                outdir           = "$outputDir"
                genome_fasta     = "https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/genome/genome.fasta"
                gtf              = "https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/sarscov2/genome/genome.gtf"
                transcript_fasta = "https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/sarscov2/genome/transcriptome.fasta"
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.trace.succeeded().size() > 0 },
                { assert path("$outputDir/salmon").exists() },
                { assert snapshot(
                    // Snapshot only deterministic quantification outputs;
                    // aux_info/ (fld.gz, meta_info.json) and logs/ (salmon_quant.log)
                    // are non-deterministic and excluded.
                    path("$outputDir/salmon/test/quant.sf"),
                    path("$outputDir/salmon/test/quant.genes.sf"),
                    path("$outputDir/salmon/test/lib_format_counts.json"),
                    path("$outputDir/salmon/test/cmd_info.json")
                ).match() }
            )
        }
    }
}
